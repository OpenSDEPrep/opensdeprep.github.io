---
// Multi-language code tab switcher for MDX.
// Usage:
//   <CodeTabs tabs={['Python', 'Java']}>
//     <Fragment slot="Python">```py ... ```</Fragment>
//     <Fragment slot="Java">```java ... ```</Fragment>
//   </CodeTabs>
interface Props {
  tabs: string[];
}
const { tabs } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---
<div class="code-tabs" data-code-tabs>
  <div class="code-tabs__bar" role="tablist">
    {tabs.map((tab, i) => (
      <button
        type="button"
        role="tab"
        class="code-tabs__tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        data-tab={`${uid}-${i}`}
      >{tab}</button>
    ))}
  </div>
  {tabs.map((tab, i) => (
    <div class="code-tabs__panel" data-panel={`${uid}-${i}`} hidden={i !== 0}>
      <slot name={tab} />
    </div>
  ))}
</div>

<style>
  .code-tabs { margin: var(--space-lg) 0; border: 1px solid var(--color-border); border-radius: var(--radius-md); overflow: hidden; }
  .code-tabs__bar { display: flex; gap: 0; background: var(--color-neutral); border-bottom: 1px solid var(--color-border); }
  .code-tabs__tab {
    border: 0; background: transparent; cursor: pointer;
    font-family: var(--font-mono); font-size: 13px; padding: 8px 14px; color: var(--color-muted);
  }
  .code-tabs__tab[aria-selected='true'] { color: var(--color-primary); box-shadow: inset 0 -2px 0 var(--color-tertiary); }
  .code-tabs__panel :global(pre) { margin: 0; border-radius: 0; }
</style>

<script>
  document.querySelectorAll('[data-code-tabs]').forEach((root) => {
    const tabs = root.querySelectorAll<HTMLButtonElement>('[data-tab]');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        tabs.forEach((t) => t.setAttribute('aria-selected', String(t === tab)));
        root.querySelectorAll<HTMLElement>('[data-panel]').forEach((p) => {
          p.hidden = p.dataset.panel !== id;
        });
      });
    });
  });
</script>

---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
<nav class="breadcrumb" aria-label="Breadcrumb">
  <ol>
    {items.map((item, i) => (
      <li>
        {item.href && i < items.length - 1 ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
        {i < items.length - 1 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
  }
  .breadcrumb li { display: flex; gap: var(--space-xs); align-items: center; }
  .breadcrumb__sep { color: var(--color-border); }
  .breadcrumb [aria-current='page'] { color: var(--color-secondary); }
</style>

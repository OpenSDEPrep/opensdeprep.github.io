---
import { TOPIC_META, TOPIC_ORDER, type Topic } from '../lib/topics';
import { href } from '../lib/url';

interface Props {
  counts: Record<Topic, number>;
}
const { counts } = Astro.props;
---
<div class="topic-grid">
  {TOPIC_ORDER.map((t) => {
    const meta = TOPIC_META[t];
    return (
      <a class="topic-card" href={href(`/${t}`)}>
        <span class="eyebrow">{meta.label}</span>
        <p class="topic-card__desc">{meta.description}</p>
        <span class="topic-card__count">{counts[t]} article{counts[t] === 1 ? '' : 's'}</span>
      </a>
    );
  })}
</div>

<style>
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }
  .topic-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    color: var(--color-primary);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .topic-card:hover {
    border-color: var(--color-tertiary);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .topic-card__desc { margin: 0; color: var(--color-secondary); font-size: 15px; }
  .topic-card__count {
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-muted);
  }
</style>

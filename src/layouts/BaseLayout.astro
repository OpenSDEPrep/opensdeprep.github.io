---
import '../styles/global.css';
import SearchBar from '../components/SearchBar.astro';
import { TOPIC_META, TOPIC_ORDER } from '../lib/topics';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Open-source SDE interview prep & engineering learning hub.' } = Astro.props;
const siteName = 'OpenSDEPrep';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__brand">OpenSDEPrep</a>
        <nav class="site-header__nav" aria-label="Topics">
          {TOPIC_ORDER.map((t) => (
            <a href={`/${t}`}>{TOPIC_META[t].label}</a>
          ))}
        </nav>
        <SearchBar />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          OpenSDEPrep — open-source SDE interview prep.
          <a href="https://github.com/OpenSDEPrep">GitHub</a>
        </p>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: color-mix(in srgb, var(--color-surface) 88%, transparent);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--color-border);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        gap: var(--space-lg);
        height: 60px;
      }
      .site-header__brand {
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--color-primary);
        font-size: 18px;
      }
      .site-header__nav {
        display: flex;
        gap: var(--space-md);
        flex: 1;
        flex-wrap: wrap;
      }
      .site-header__nav a {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-secondary);
      }
      .site-header__nav a:hover { color: var(--color-tertiary); text-decoration: none; }
      .site-footer {
        margin-top: var(--space-4xl);
        border-top: 1px solid var(--color-border);
        padding-block: var(--space-xl);
        color: var(--color-muted);
        font-size: 14px;
      }
      @media (max-width: 720px) {
        .site-header__nav { display: none; }
      }
    </style>
  </body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicGrid from '../components/TopicGrid.astro';
import FilterBar from '../components/FilterBar.astro';
import { getArticleCounts } from '../lib/articles';

const counts = await getArticleCounts();
const total = Object.values(counts).reduce((a, b) => a + b, 0);
---
<BaseLayout title="OpenSDEPrep">
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Open-source · static · no tracking</span>
      <h1 class="hero__title">SDE interview prep, structured for deep reading.</h1>
      <p class="hero__lede">
        Patterns, system design, and runtime internals — curated from primary sources.
        {total} article{total === 1 ? '' : 's'} across six topics.
      </p>
    </div>
  </section>

  <section class="container section">
    <FilterBar showRoles={true} />
    <TopicGrid counts={counts} />
  </section>
</BaseLayout>

<style>
  .hero {
    background:
      radial-gradient(1200px 400px at 70% -10%, color-mix(in srgb, var(--color-tertiary) 12%, transparent), transparent),
      var(--color-neutral);
    padding-block: var(--space-4xl) var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }
  .hero__title { font-size: 56px; letter-spacing: -0.04em; line-height: 1.05; margin: var(--space-md) 0; max-width: 16ch; }
  .hero__lede { font-size: 18px; color: var(--color-secondary); max-width: 56ch; margin: 0; }
  .section { padding-block: var(--space-2xl); }
  @media (max-width: 720px) {
    .hero__title { font-size: 38px; }
  }
</style>
